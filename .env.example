# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/springboot_db
DB_USERNAME=springboot_user
DB_PASSWORD=your_db_password_here

# ── Email (Gmail SMTP App Password) ───────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_base64_jwt_secret_here

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Application URLs ──────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Invoice PDF Storage (absolute path, cross-platform) ───────────────────────
INVOICE_STORAGE_PATH=/app/pdf_storage
